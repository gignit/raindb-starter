{
  "raindb": {
    "formations": [
      { "id": "starter-notes", "ops": ["read", "write", "list"] }
    ],
    "secrets": {
      "names": [
        "LLM_API_BASE",
        "LLM_API_KEY",
        "RAINDB_GRAPHQL_ENDPOINT",
        "RAINDB_GRAPHQL_KEY"
      ]
    }
  },
  "network": {
    "egress": ["api.rtest.raindb.io"],
    "fetch": {
      "allowedHosts": ["api.rtest.raindb.io"]
    }
  },
  "limits": {
    "cpuMs": 30000,
    "memoryMb": 512,
    "wallMs": 60000
  }
}
